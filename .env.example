# Copiez ce fichier en ".env" et renseignez les valeurs.

# Base de données PostgreSQL (Neon en ligne, ou un Postgres local).
# Exemple Neon : postgresql://user:motdepasse@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:motdepasse@localhost:5432/aragon?schema=public"

# --- Stockage des fichiers (Cloudinary, FACULTATIF) ---
# Laissez vide pour stocker les pièces jointes sur le disque local.
# Renseignez ces 3 valeurs (tableau de bord Cloudinary) pour un stockage
# durable en ligne des photos et documents.
# CLOUDINARY_CLOUD_NAME="votre-cloud-name"
# CLOUDINARY_API_KEY="votre-api-key"
# CLOUDINARY_API_SECRET="votre-api-secret"

# Secret de chiffrement des cookies de session (32+ caractères).
# Générez-en un avec :  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET="remplacez-moi-par-une-chaine-aleatoire-de-32-caracteres-minimum"

# --- E-mails (FACULTATIF) ---
# Laissez vide pour un usage 100% local : les e-mails sont alors seulement
# affichés dans la console. Renseignez ces valeurs (chez un fournisseur SMTP)
# pour envoyer de vrais e-mails une fois la plateforme en ligne.
# SMTP_HOST="smtp.exemple.com"
# SMTP_PORT="587"
# SMTP_USER="votre-identifiant"
# SMTP_PASS="votre-mot-de-passe"
# SMTP_FROM="Collectif Aragon <no-reply@votre-domaine.fr>"
# APP_URL="https://votre-domaine.fr"
